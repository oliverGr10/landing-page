---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'MISTHEC — Agencia de Desarrollo Digital de Alto Impacto',
  description = 'Expertos en creación de Landing Pages, Sitios Web y Apps para móvil y desktop en Arequipa. Impulsamos tu presencia digital con diseño premium y tecnología de punta.',
  image = '/images/photo-1498050108023-c5249f4df085.avif',
} = Astro.props;

const canonicalURL = Astro.url;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0e1a" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="MISTHEC" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "MISTHEC",
        "description": "Agencia de desarrollo de productos digitales, sitios web y aplicaciones en Arequipa",
        "url": "https://misthec.com",
        "logo": "https://misthec.com/images/logo.png",
        "sameAs": [
          "https://twitter.com/misthec",
          "https://linkedin.com/company/misthec"
        ]
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
