---
const benefits = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-zap"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: "Velocidad Extrema",
    description: "Desarrollamos sitios optimizados para cargar en menos de 1 segundo, garantizando la mejor experiencia y SEO.",
    stat: "< 1s",
    statLabel: "Carga rápida",
    color: "#9b6dff",
    span: "col-span-2",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-palette"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.6-.7 1.6-1.6 0-.4-.2-.8-.5-1.1s-.4-.8-.4-1.2c0-.9.7-1.6 1.6-1.6h5.8c.9 0 1.6-.7 1.6-1.6 0-4.4-4.2-8-9.1-8z"/></svg>`,
    title: "Diseño Exclusivo",
    description: "Interfaces únicas y personalizadas que reflejan la esencia de tu marca.",
    stat: "100%",
    statLabel: "Diseño único",
    color: "#6c3fc5",
    span: "col-span-1",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-monitor"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: "Multi-Plataforma",
    description: "Landing pages, sitios web corporativos y apps móviles nativas.",
    stat: "Cross",
    statLabel: "Compatible",
    color: "#1a3a8f",
    span: "col-span-1",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
    title: "SEO & Estrategia",
    description: "Estructuramos tu sitio para dominar los motores de búsqueda y convertir visitantes en clientes.",
    stat: "Top 3",
    statLabel: "Ranking Google",
    color: "#9b6dff",
    span: "col-span-2",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cpu"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>`,
    title: "Tecnología Senior",
    description: "Escalabilidad y seguridad garantizadas con el stack más moderno.",
    stat: "2024",
    statLabel: "Next-gen Tech",
    color: "#6c3fc5",
    span: "col-span-1",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-headset"><path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-5Zm0 0a9 9 0 1 1 18 0m0 0h-3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2v-5Z"/><path d="M21 16v2a2 2 0 0 1-2 2h-5"/></svg>`,
    title: "Soporte 24/7",
    description: "Te acompañamos en cada fase del proyecto con mantenimiento continuo.",
    stat: "Elite",
    statLabel: "Soporte VIP",
    color: "#1a3a8f",
    span: "col-span-1",
  },
];
---

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("DOMContentLoaded", () => {
    gsap.from("#benefitsHeader", {
      opacity: 0,
      y: -20,
      duration: 0.8,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#beneficios",
        start: "top 80%",
      },
    });

    gsap.from(".benefit-card", {
      opacity: 0,
      y: 30,
      stagger: 0.15,
      duration: 0.8,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#benefitsGrid",
        start: "top 80%",
      },
    });
  });
</script>

<section class="benefits section" id="beneficios">
  <div class="container">
    <div class="benefits__header" id="benefitsHeader">
      <div class="section-label">
        <span class="dot"></span>
        Nuestras Ventajas
      </div>
      <h2>
        Soluciones digitales que<br /><span class="text-gradient"
          >transforman tu negocio</span>
      </h2>
      <p>
        Combinamos diseño de vanguardia con desarrollo de alto nivel para crear productos digitales que realmente funcionan.
      </p>
    </div>

    <div class="benefits__grid" id="benefitsGrid">
      {
        benefits.map((b, i) => (
          <div
            class={`benefit-card ${b.span}`}
            data-index={i}
            style={`--accent: ${b.color}`}
          >
            <div class="benefit-card__glow" />
            <div class="benefit-card__icon" set:html={b.icon} />
            <div class="benefit-card__body">
              <h3>{b.title}</h3>
              <p>{b.description}</p>
            </div>
            <div class="benefit-card__stat">
              <span class="stat-val">{b.stat}</span>
              <span class="stat-lbl">{b.statLabel}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .benefits {
    background: linear-gradient(
      180deg,
      var(--blue-dark) 0%,
      var(--blue-mid) 50%,
      var(--blue-dark) 100%
    );
    position: relative;
    overflow: hidden;
  }

  .benefits::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(
      circle,
      rgba(108, 63, 197, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .benefits__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .benefits__header h2 {
    margin-bottom: 1rem;
  }
  .benefits__header p {
    max-width: 540px;
    margin: 0 auto;
  }

  .text-gradient {
    background: linear-gradient(135deg, #9b6dff 0%, #6c3fc5 50%, #1a3a8f 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-flow: dense;
    gap: 1.5rem;
  }

  .col-span-1 {
    grid-column: span 1;
  }

  .benefit-card {
    position: relative;
    background: var(--gradient-card);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: var(--radius);
    padding: 2rem;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
    cursor: default;
  }

  .benefit-card:hover {
    transform: translateY(-4px);
    border-color: rgba(155, 109, 255, 0.25);
  }

  .benefit-card:hover .benefit-card__glow {
    opacity: 1;
  }

  .benefit-card__glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .benefit-card__icon {
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--accent);
    padding: 12px;
    transition:
      background 0.3s,
      transform 0.3s;
  }

  .benefit-card:hover .benefit-card__icon {
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  .benefit-card__icon svg {
    width: 100%;
    height: 100%;
  }

  .benefit-card__body h3 {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    color: var(--white);
  }

  .benefit-card__body p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--white-dim);
  }

  .benefit-card__stat {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .stat-val {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent);
  }

  .stat-lbl {
    font-size: 0.8rem;
    color: var(--white-dim);
  }

  @media (max-width: 900px) {
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .benefits__grid {
      grid-template-columns: 1fr;
    }
    .hide-mobile {
      display: none;
    }
  }
</style>
